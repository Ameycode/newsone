    {
      "parameters": {
        "jsCode": "const seen = new Set();\n\nreturn items.filter(item => {\n  const title = item.json.title\n    ?.toLowerCase()\n    .trim();\n\n  if (!title) return false;\n\n  if (seen.has(title)) {\n    return false;\n  }\n\n  seen.add(title);\n\n  return true;\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        688,
        48
      ],
      "id": "ad7e9e2f-9cc0-4eba-9131-5bd290ca7c72",
      "name": "Code in JavaScript"
    },
    {
      "parameters": {
        "jsCode": "return items.map(item => ({\n  json: {\n    title: item.json.title || \"\",\n    \n    description:\n      item.json.contentSnippet ||\n      item.json.content ||\n      item.json.summary ||\n      \"\",\n\n    link: item.json.link || \"\",\n\n    publishedDate:\n      item.json.isoDate ||\n      item.json.pubDate ||\n      \"\",\n\n    source:\n      item.json.creator ||\n      item.json.source ||\n      item.json.feedTitle ||\n      \"Unknown\",\n\n    image:\n      item.json.enclosure?.url ||\n      item.json[\"media:content\"]?.url ||\n      \"\"\n  }\n}));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        896,
        48
      ],
      "id": "4927ce90-03e7-4953-a9fc-472528f74646",
      "name": "Code in JavaScript1"
    },
    {
      "parameters": {
        "jsCode": "items.sort((a, b) => {\n  return new Date(\n    b.json.publishedDate\n  ) - new Date(\n    a.json.publishedDate\n  );\n});\n\nreturn items;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1072,
        48
      ],
      "id": "fd8b60c0-5e8a-444b-b322-52e904c812bf",
      "name": "Code in JavaScript2"
    },
    {
      "parameters": {
        "jsCode": "return items.slice(0, 50);"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1280,
        48
      ],
      "id": "e2ce7f36-b5b6-463a-a29c-11a5b4f2edf0",
      "name": "Code in JavaScript3"
    },
    {
      "parameters": {
        "jsCode": "return [\n  {\n    json: {\n      success: true,\n      count: items.length,\n      news: items.map(\n        item => item.json\n      )\n    }\n  }\n];"
      },
